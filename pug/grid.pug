
extends ./_layout/navi.pug
block vars
	- const title = 'GRID'
block contents
	.g
		.box= '0123456789'.repeat(200)
		.g-card
			.header
				.left
					span.material-symbols-outlined share
				.center
					span.material-symbols-outlined person
					| HEADERRRRRRRRRRRRRR
				.right
					span.material-symbols-outlined key_vertical
			.body
				p= '0123456789'.repeat(200)
			.footer FOOTER
		.g-card
			.header HEADERRRRRRRRRRRRRR
				.right
					span.material-symbols-outlined key_vertical
			.body
				p= '0123456789'.repeat(200)
			.footer FOOTER
		.g-card
			.header HEADERRRRRRRRRRRRRR
				.left
					span.material-symbols-outlined share
			.body
				p= '0123456789'.repeat(200)
		each _ in Array(10)
			.box 0123456789
	style
		:scss
			@mixin scrollbar {
				&::-webkit-scrollbar {
					width: 14px;
				}
				&::-webkit-scrollbar-track {
					background: transparent;
				}
				&::-webkit-scrollbar-thumb {
					background-color: #888;
					border-radius: 10px;
					border: 4px solid transparent;
					background-clip: padding-box;
				}
			}
			.box {
				@include scrollbar;
				padding: .5rem;
				border-radius: .5rem;
				word-break: break-all;
				overflow-y: scroll;
				min-height: 0;
			}
			@mixin gCardHeaderFooter {
				position: relative;
				padding: 0 2.4rem;
				line-height: 2.4rem;
				text-align: center;
				font-size: 1.2rem;
				font-weight: bold;
				user-select: none;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
				.center {
					display: flex;
					align-items: center;
					gap: .3rem;
					overflow: hidden;
					white-space: nowrap;
					text-overflow: ellipsis;
				}
				.left, .right {
					position: absolute;
					top: 0;
					bottom: 0;
					display: flex;
					align-items: center;
				}
				.left { left: .2rem; }
				.right { right: .2rem; }
			}
			.g {
				display: grid;
				gap: .5rem;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				grid-auto-rows: 400px;
				.g-card {
					display: grid;
					grid-template-rows: auto 1fr auto;
					height: 100%;
					min-height: 0;
					border: 1px solid #ccc;
					border-radius: .5rem;
					.header {
						@include gCardHeaderFooter;
					}
					.body {
						@include scrollbar;
						padding-left: .5rem;
						overflow-y: scroll;
						word-break: break-all;
					}
					.footer {
						@include gCardHeaderFooter;
					}
				}
			}

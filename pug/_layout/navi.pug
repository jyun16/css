	script.
		let menu = false
		let menuRight = false
		const modalBgFunc = (close) => {
			return (flag=true) => {
				if (flag) {
					$('#modal-bg').addClass('on')
				}
				else {
					$('#modal-bg').removeClass('on')
					$('.open').removeClass('open')
					close()
				}
			}
		}
		const menuModalBg = modalBgFunc(() => {
			menu = false
			menuRight = false
		})
		$('#modal-bg').click(function() { menuModalBg(false) })
		$('#menu-button').click(function() {
			menu = !menu
			if (menu) {
				$('#menu').addClass('open')
				menuModalBg()
			}
			return false
		})
		$('#menu-right-button').click(function() {
			menuRight = !menuRight
			if (menuRight) {
				$('#menu-right').addClass('open')
				menuModalBg()
			}
			return false
		})
		const openSubMenu = ($item) => {
			if ($item.data('open')) {
				$item.data('open', false)
				$item.find('.sub-item-container').removeClass('open')
				$item.find('.sub-icon').removeClass('open')
			}
			else {
				$item.data('open', true)
				$item.find('.sub-item-container').addClass('open')
				$item.find('.sub-icon').addClass('open')
			}
		}
		$('.item').click(function() {
			const $item = $(this)
			const url = $item.attr('href')
			if (url) { location.href = url; }
			else { openSubMenu($item) }
		})
		$('.sub-item').click(function() {
			const $item = $(this)
			const url = $item.attr('href')
			if (url) { location.href = url; }
		})
		const menuActive = () => {
			const path = location.pathname
			$(`a.header-icon[href='${path}']`).addClass('active')
			$(`.item[href='${path}']`).addClass('active')
			openSubMenu($(`.sub-item[href='${path}']`).addClass('active').parent().parent())
		}
		menuActive()

extends ./_layout/navi.pug
block vars
	- const title = 'DIALOG'
block contents
	.fc
		button.primary#open
			span.icon launch
			span OPEN
		dialog#dialog.vw30(autofocus)
			.card.vh30
				.header
					span.icon person
					span= 'INFO'.repeat(10)
					.right
						span.close.icon close
				.body(tabindex='-1')
					p= '0123456789'.repeat(500)
				.footer
					button.primary.close(autofocus) CLOSE
	.fc.fb.h40
		button.primary.open-sticky-dialog
			span.icon launch
			span OPEN
	.fc.fb.h50
		button.primary.open-sticky-dialog
			span.icon launch
			span OPEN
	script.
		const d = console.log
		const $dialog = $('#dialog')
		$('#open').click(() => {
			$dialog.removeClass('sticky-dialog')
			$dialog[0].showModal();
			$dialog[0].blur()
		})
		$('.open-sticky-dialog').click(e => {
			$('.open-sticky-dialog').removeClass('dialog-anchor')
			$(e.currentTarget).addClass('dialog-anchor')
			$dialog.addClass('sticky-dialog')
			$dialog[0].showModal();
		})
		$('.close').click(() => {
			$dialog[0].close()
		})

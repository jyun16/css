	style
		:scss
			#dialog {
				margin: auto;
				.body {
					&:focus { outline: none; }
				}
				&::backdrop {
					background: rgba(0, 0, 0, 0.6);
				}
			}
			.sticky-dialog {
				position: fixed;
				margin: 0 !important;
				position-anchor: --anchor;
				top: anchor(bottom);
				left: anchor(left);
				position-try-fallbacks: flip-block, flip-inline;
			}
			.dialog-anchor {
				anchor-name: --anchor
			}

extends ./_layout/navi.pug
block append head
	script(src='/js/select-pure/select-pure.min.js')
	link(href='/js/select-pure/select-pure.min.css' rel='stylesheet')
block vars
	- const title = 'FORM'
block contents
	form
		.label INPUT
		input(placeholder='EXAMPLE')
		.label TEXTAREA
		textarea(placeholder='EXAMPLE\nEXAMPLE')
		.label TIME
		.j-time
			input.hour(type='text' inputmode='numeric' pattern='\d*' maxlength='2' placeholder='HH')
			span :
			input.minute(type='text' inputmode='numeric' pattern='\d*' maxlength='2' placeholder='MM')
		.label DATE
		.j-date
			input.year(type='text' inputmode='numeric' pattern='\d*' maxlength='4' placeholder='yyyy')
			span -
			input.month(type='text' inputmode='numeric' pattern='\d*' maxlength='2' placeholder='mm')
			span -
			input.day(type='text' inputmode='numeric' pattern='\d*' maxlength='2' placeholder='dd')
		.label SELECT
		#select
		.label RADIO
		.fv
			label
				input(type='radio' name='radio' checked)
				span ONE
			label
				input(type='radio' name='radio')
				span TWO
			label
				input(type='radio' name='radio')
				span THREE
		.label CHECKBOX
		.fv
			label
				input(type='checkbox' checked)
				span ONE
			label
				input(type='checkbox' checked)
				span TWO
			label
				input(type='checkbox')
				span THREE
		.label CALENDAR
		input#calendar
		dialog#calendar-dialog
			.card
				.header
					span.icon.pointer arrow_left
					span.pointer 2026-01
					span.icon.pointer arrow_right
				.body
					- for (let n=1; n<=30; n++) 
						div #{n}
				.footer
					button 今日
		.label RICH SELECT
		#rich-select
			.items
				.item
					span ほげほげ
					span.icon.close close
				.item ふがふが
					span.icon.close close
		dialog#rich-select-dialog
			.input
				input(placeholder='...')
			.option HOGE
			.option FUGA
			.option FOO
			.option BAR
		.fc
			button BUTTON
			button.primary SUBMIT
			button.secondary.ml-2 CANCEL
	script.
		const d = console.log

		$('.j-time input').on('focus', function() {
			this.select()
		})
		$('.j-time input').on('keydown', function(e) {
			let isHour = $(this).hasClass('hour')
			let max = isHour ? 23 : 59
			let val = parseInt(this.value || 0)
			if (e.key === 'ArrowUp') {
				e.preventDefault()
				val = val >= max ? 0 : val + 1
				this.value = String(val).padStart(2, '0')
				this.select()
			}
			else if (e.key === 'ArrowDown') {
				e.preventDefault()
				val = val <= 0 ? max : val - 1
				this.value = String(val).padStart(2, '0')
				this.select()
			}
			else if (e.key === 'ArrowRight' && isHour && this.selectionStart === this.value.length) {
				e.preventDefault()
				$(this).nextAll('input').focus()
			}
			else if ((e.key === 'ArrowLeft' || e.key === 'Backspace') && !isHour && this.selectionStart === 0) {
				e.preventDefault()
				$(this).prevAll('input').focus()
			}
		})
		$('.j-time input').on('input', function() {
			this.value = this.value.replace(/\D/g, '')
			if (this.value.length === 2 && $(this).hasClass('hour')) {
				$(this).nextAll('input').focus()
			}
		})
		$('.j-time input').on('blur', function() {
			if (this.value) {
				let isHour = $(this).hasClass('hour')
				let max = isHour ? 23 : 59
				let v = parseInt(this.value)
				if (v > max) v = max
				this.value = String(v).padStart(2, '0')
			}
		})

		$('.j-date input').on('focus', function() {
			this.select()
		})
		$('.j-date input').on('keydown', function(e) {
			const $this = $(this)
			let val = parseInt(this.value || 0)
			if (e.key === 'ArrowUp' || e.key === 'ArrowDown') {
				e.preventDefault()
				let isYear = $this.hasClass('year')
				let isMonth = $this.hasClass('month')
				let step = (e.key === 'ArrowUp') ? 1 : -1
				if (isYear) {
					val += step
				}
				else if (isMonth) {
					val = (val + step - 1 + 12) % 12 + 1
				}
				else {
					val = (val + step - 1 + 31) % 31 + 1
				}
				this.value = isYear ? val : String(val).padStart(2, '0')
				this.select()
			}
			else if (e.key === 'ArrowRight' && this.selectionStart === this.value.length) {
				$this.nextAll('input').first().focus()
			}
			else if ((e.key === 'ArrowLeft' || e.key === 'Backspace') && this.selectionStart === 0) {
				$this.prevAll('input').first().focus()
			}
		})
		$('.j-date input').on('input', function() {
			this.value = this.value.replace(/\D/g, '')
			let limit = $(this).hasClass('year') ? 4 : 2
			if (this.value.length >= limit) {
				$(this).nextAll('input').first().focus()
			}
		})
		$('.j-date input').on('blur', function() {
			const $parent = $(this).closest('.j-date')
			const y = parseInt($parent.find('.year').val()) || new Date().getFullYear()
			const m = parseInt($parent.find('.month').val()) || 1
			const d = parseInt($parent.find('.day').val()) || 1
			let mm = Math.max(1, Math.min(12, m))
			let tempDate = new Date(y, mm - 1, d)
			if (tempDate.getMonth() + 1 !== mm) {
				tempDate = new Date(y, mm, 0)
			}
			const finalY = Math.max(1900, y)
			const finalM = tempDate.getMonth() + 1
			const finalD = tempDate.getDate()
			$parent.find('.year').val(finalY)
			$parent.find('.month').val(String(finalM).padStart(2, '0'))
			$parent.find('.day').val(String(finalD).padStart(2, '0'))
		})

		new SelectPure('#select', {
			options: [
				{ 'label': 'ほげほげ', 'value': '1' },
				{ 'label': 'ふがふが', 'value': '2' },
				{ 'label': 'ふーふー', 'value': '3' },
				{ 'label': 'ばーばー', 'value': '4' },
			],
			value: [ '1', '2', '3' ],
			multiple: true,
			autocomplete: true,
			onChange: v => { console.log(v) },
		})
		const $cal = $('#calendar-dialog')
		$('#calendar').click(() => { $cal[0].showModal(); })
		$('#rich-select .close').click(() => { alert('close') })
		const $rs = $('#rich-select-dialog')
		$('#rich-select').click(() => { $rs[0].showModal(); })
		$('dialog').click(function(e) { if (e.target === this) { this.close() } })
	style
		:scss
			input.time {
				width: 3.5rem;
			}

			.j-time {
				display: inline-flex;
				align-items: center;
				width: 4.4rem;
				height: 2.5rem;
				padding: .2rem .2rem;
				color: #444;
				background: #fff;
				border-radius: 4px;
				cursor: text;
				input {
					width: 1.8rem;
					padding: 0;
					text-align: center;
					background: transparent;
					border: none;
					outline: none;
				}
			}

			.j-date {
				display: inline-flex;
				align-items: center;
				width: 8rem;
				height: 2.5rem;
				padding: .2rem .4rem;
				color: #444;
				background: #fff;
				border-radius: 4px;
				cursor: text;
				input {
					&.year { width: 2.6rem; }
					&.month { width: 2.2rem; }
					&.day { width: 1.8rem; }
					padding: 0;
					text-align: center;
					background: transparent;
					border: none;
					outline: none;
				}
			}

			#calendar {
				anchor-name: --calendar;
			}
			#calendar-dialog {
				position: fixed;
				position-anchor: --calendar;
				position-area: top;
				position-try-fallbacks: bottom;
				max-width: 280px;
				max-height: 320px;
				margin: 2px 0 !important;
				&::backdrop {
					background: rgba(0, 0, 0, 0.6);
				}
				.body {
					display: grid;
					grid-template-columns: repeat(7, 1fr);
					gap: .2rem;
					> div {
						display: flex;
						justify-content: center;
						width: 2rem;
					}
				}
			}

			#rich-select {
				anchor-name: --rich-select;
				display: grid;
				align-items: center;
				background: #fff;
				border-radius: 5px;
				cursor: pointer;
				user-select: none;
				.items {
					display: flex;
					align-items: center;
					gap: .3rem;
					height: 2.5rem;
					padding: 0 .5rem;
					.item {
						display: flex;
						align-items: center;
						height: 1.8rem;
						padding: .1rem .3rem .2rem .4rem;
						color: #fff;
						background: #5e6264;
						border-radius: .2rem;
						cursor: default;
						.close {
							cursor: pointer;
						}
					}
				}
			}
			#rich-select-dialog {
				position: fixed;
				position-anchor: --rich-select;
				position-area: bottom;
				position-try-fallbacks: top;
				width: anchor-size(width);
				max-height: 300px;
				margin: 2px 0 !important;
				overflow-y: auto;
				color: #444;
				background: #fff;
				border-radius: .5rem;
				&::backdrop {
					background: rgba(0, 0, 0, 0.6);
				}
				.input {
					position: relative;
					input {
						width: 100%;
						padding-right: 2.2rem;
						border-top: 1px solid #ccc;
						&:focus-visible {
							outline: none;
						}
					}
					&::after {
						content: '\e8b6';
						font-family: 'Material Symbols Outlined';
						position: absolute;
						top: .2rem;
						right: 10px;
						font-size: 1.5rem;
						color: #999;
						pointer-events: none;
					}
				}
				.option {
					height: 2.5rem;
					padding: .2rem .5rem;
					border-top: 1px solid #ccc;
					cursor: pointer;
					&:hover {
						color: #fff;
						background: #444;
					}
				}
			}

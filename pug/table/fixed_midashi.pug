extends ../_layout/navi.pug
block vars
	- const title = 'テスト'
block append head
	script(src='/js/fixed_midashi/fixed_midashi.min.js')
block contents
	style.
		body {
			padding: 100px;
		}
		table {
			white-space: nowrap;
			border-collapse: collapse;
			th, td {
				border: 1px solid #eee;
				padding: 4px 8px;
			}
		}
		div.scroll_div { overflow: auto; }
	- const COLS = 30
	- const ROWS = 100
	.scroll_div
		table(_fixedhead="rows:1; cols:1")
			thead
				tr
					- for (let i = 1; i <= COLS; i++)
						th フィールド #{i}
			tbody
				- for (let j = 1; j <= ROWS; j++)
					tr
						- for (let i = 1; i <= COLS; i++)
							td データ #{j} #{i}
		script.
			FixedMidashi.create()
